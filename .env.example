# Example environment variables for this project
# Copy this file to `.env` and replace placeholders with real values.

# API Configuration
API_BASE_URL=https://api.example.com/v1

# Analytics & Monitoring
SENTRY_DSN=your_sentry_dsn_here
SENTRY_URL=https://sentry.io/
SENTRY_ORG=YOUR_SENTRY_ORG
SENTRY_PROJECT=YOUR_SENTRY_PROJECT
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# In-App Purchases (RevenueCat)
REVENUECAT_IOS_KEY=your_revenuecat_ios_key_here
REVENUECAT_ANDROID_KEY=your_revenuecat_android_key_here
# Optional: Test/Sandbox keys for development
REVENUECAT_IOS_KEY_TEST=your_revenuecat_ios_test_key_here
REVENUECAT_ANDROID_KEY_TEST=your_revenuecat_android_test_key_here

# Advertising (AppLovin MAX)
APPLOVIN_SDK_KEY=your_applovin_sdk_key_here
APPLOVIN_BANNER_AD_UNIT_IOS=your_ios_banner_ad_unit_id
APPLOVIN_BANNER_AD_UNIT_ANDROID=your_android_banner_ad_unit_id
APPLOVIN_INTERSTITIAL_AD_UNIT_IOS=your_ios_interstitial_ad_unit_id
APPLOVIN_INTERSTITIAL_AD_UNIT_ANDROID=your_android_interstitial_ad_unit_id
APPLOVIN_REWARDED_AD_UNIT_IOS=your_ios_rewarded_ad_unit_id
APPLOVIN_REWARDED_AD_UNIT_ANDROID=your_android_rewarded_ad_unit_id
APPLOVIN_APP_OPEN_AD_UNIT_IOS=your_ios_app_open_ad_unit_id
APPLOVIN_APP_OPEN_AD_UNIT_ANDROID=your_android_app_open_ad_unit_id

# Google AdMob Application IDs (Required for AdMob Mediation Adapter)
# Get these from: https://apps.admob.com/
# Format: ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
ADMOB_APP_ID_IOS=ca-app-pub-3940256099942544~1458002511
ADMOB_APP_ID_ANDROID=ca-app-pub-3940256099942544~3347511713

# Facebook SDK
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_TOKEN=your_facebook_client_token_here
FACEBOOK_DISPLAY_NAME=MyApp

# Attribution (AppsFlyer)
APPSFLYER_DEV_KEY=your_appsflyer_dev_key_here
APPSFLYER_APP_ID=your_ios_app_id_here

# Social Sign-In (Optional - Leave empty if not configured)
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here.apps.googleusercontent.com
APPLE_SERVICE_ID=your_apple_service_id_here

USER_CENTRIC=''

WEB_CLIENT_ID='your_web_client_id_here.apps.googleusercontent.com'
IOS_CLIENT_ID='your_ios_client_id_here.apps.googleusercontent.com'

OPEN_AI=your_openai_api_key_here

# Notes:
# - Do not commit a real `.env` to version control. Keep secrets out of the repo.
# - If you use `react-native-dotenv`, ensure the keys above are exposed by your
#   bundler config (babel plugin) and that `.env` is loaded during builds.

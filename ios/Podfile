# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Use static frameworks - required for Firebase Swift pods to generate proper headers
use_frameworks! :linkage => :static

# react-native-permissions configuration
# Only include the permissions you need to reduce app size
def node_require(script)
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve('#{script}', {paths: [process.argv[1]]})", __dir__]).strip
end

node_require('react-native-permissions/scripts/setup.rb')

setup_permissions([
  'Camera',
  'PhotoLibrary',
])

target 'CosmicMarkcon' do
  config = use_native_modules!
  
  # Enable modular headers for Firebase dependencies that require it
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'nanopb', :modular_headers => true
  pod 'FirebaseABTesting', :modular_headers => true
  pod 'FirebaseRemoteConfig', :modular_headers => true
  pod 'FirebaseAuthInterop', :modular_headers => true
  pod 'FirebaseAppCheckInterop', :modular_headers => true
  pod 'RecaptchaInterop', :modular_headers => true

  # ========================================
  # AppLovin Mediation Adapters
  # ========================================
  # Temporarily disabled Facebook adapter due to iOS build issues
  # pod 'AppLovinMediationFacebookAdapter'
  pod 'AppLovinMediationGoogleAdapter'
  pod 'AppLovinMediationUnityAdsAdapter'
  pod 'AppLovinMediationIronSourceAdapter'
  pod 'AppLovinMediationVungleAdapter'
  pod 'AppLovinMediationMintegralAdapter'
  pod 'AppLovinMediationFyberAdapter'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Exclude x86_64 architecture for Apple Silicon Macs (required for AppsFlyer)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'x86_64'
        
        # Force dSYM generation for all pods
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
        config.build_settings['GENERATE_DSYM'] = 'YES'
        
        # Fixes for AppLovin and related frameworks
        if target.name.include?('AppLovin')
          config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
          config.build_settings['COPY_PHASE_STRIP'] = 'NO'
        end
        
        # Fix for Facebook Audience Network Swift runtime issue
        if target.name.include?('FBAudienceNetwork') || target.name.include?('FBSDKCoreKit')
          config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'
          config.build_settings['LD_RUNPATH_SEARCH_PATHS'] = ['$(inherited)', '@executable_path/Frameworks', '@loader_path/Frameworks']
          config.build_settings['LIBRARY_SEARCH_PATHS'] = ['$(inherited)', '$(SDKROOT)/usr/lib/swift', '$(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)']
        end
      end
    end
  end
end

{
  "name": "CosmicMarkcon",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "generate-bootsplash": "npx react-native-bootsplash generate src/assets/SplashLogo/logo.png --platforms=android,ios --background=#FFFFFF --logo-width=100",
    "generate-app-icon": "npx react-native set-icon --path ./src/assets/AppLogo/app_logo.png --background \"#FFFFFF\"",
    "generate-app-icon:custom": "npx react-native set-icon --path ./src/assets/AppLogo/app_logo.png --background",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "ios:clean": "cd ios && rm -rf build Pods Podfile.lock && pod install && cd ..",
    "clean": "yarn android:clean && yarn ios:clean && rm -rf node_modules && yarn install",
    "postinstall": "cd ios && pod install && cd ..",
    "setup:admob": "bash src/scripts/setup-admob.sh",
    "widget:enable": "bash toggle-widget.sh enable",
    "widget:disable": "bash toggle-widget.sh disable",
    "widget:toggle": "bash toggle-widget.sh"
  },
